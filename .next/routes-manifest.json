{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/blog/[slug]",
      "regex": "^/blog/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/blog/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/about",
      "regex": "^/about(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/about(?:/)?$"
    },
    {
      "page": "/blog",
      "regex": "^/blog(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/blog(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/hire-vs-outsource-social-media",
      "regex": "^/hire\\-vs\\-outsource\\-social\\-media(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/hire\\-vs\\-outsource\\-social\\-media(?:/)?$"
    },
    {
      "page": "/portfolio",
      "regex": "^/portfolio(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portfolio(?:/)?$"
    },
    {
      "page": "/pricing",
      "regex": "^/pricing(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/pricing(?:/)?$"
    },
    {
      "page": "/robots.txt",
      "regex": "^/robots\\.txt(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/robots\\.txt(?:/)?$"
    },
    {
      "page": "/sitemap.xml",
      "regex": "^/sitemap\\.xml(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sitemap\\.xml(?:/)?$"
    },
    {
      "page": "/social-media-for-beauty-salon-singapore",
      "regex": "^/social\\-media\\-for\\-beauty\\-salon\\-singapore(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/social\\-media\\-for\\-beauty\\-salon\\-singapore(?:/)?$"
    },
    {
      "page": "/social-media-for-ecommerce-singapore",
      "regex": "^/social\\-media\\-for\\-ecommerce\\-singapore(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/social\\-media\\-for\\-ecommerce\\-singapore(?:/)?$"
    },
    {
      "page": "/social-media-for-restaurants-singapore",
      "regex": "^/social\\-media\\-for\\-restaurants\\-singapore(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/social\\-media\\-for\\-restaurants\\-singapore(?:/)?$"
    },
    {
      "page": "/social-media-manpower-singapore",
      "regex": "^/social\\-media\\-manpower\\-singapore(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/social\\-media\\-manpower\\-singapore(?:/)?$"
    }
